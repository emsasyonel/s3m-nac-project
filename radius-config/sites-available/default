server default {
    listen {
        type = auth
        ipaddr = *
        port = 0
    }
    listen {
        type = acct
        ipaddr = *
        port = 0
    }
    
    authorize {
        preprocess
        rest
        if (ok || updated) {
            update control {
                Auth-Type := rest
            }
        }
    }
    
    authenticate {
        Auth-Type rest {
            rest
            # EĞER SONUÇ OK VEYA UPDATED İSE KESİN OLARAK KABUL ET
            if (ok || updated) {
                accept
            }
        }
    }
    
    accounting {
        rest
    }
}
